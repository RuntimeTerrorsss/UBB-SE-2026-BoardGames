@model CreateRequestViewModel

@{
    ViewData["Title"] = "Create Request";
    ViewData["BackUrl"] = Url.Action("My");
}

<partial name="_PageBack" />

<div class="page-header">
    <h1 class="page-title">Create Request</h1>
</div>

<div class="form-section">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="GameId" class="form-label">Game</label>
            @if (Model.AvailableGames is null || !Model.AvailableGames.Any())
            {
                <div class="alert alert-info">No games are currently available to request.</div>
                <input type="hidden" asp-for="GameId" value="0" />
            }
            else
            {
                <select asp-for="GameId" class="form-select" id="GameId">
                    <option value="0">— Select a game —</option>
                    @foreach (var game in Model.AvailableGames)
                    {
                        <option value="@game.Id" selected="@(Model.GameId == game.Id)">@game.Name</option>
                    }
                </select>
                <span asp-validation-for="GameId" class="text-danger"></span>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Select dates</label>
            <div id="rentalDateCalendar"></div>
            <input type="hidden" asp-for="StartDate" id="StartDate" />
            <input type="hidden" asp-for="EndDate" id="EndDate" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
            <span asp-validation-for="EndDate" class="text-danger d-block"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create</button>
            <a class="btn btn-secondary" asp-action="My">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <link rel="stylesheet" href="~/css/rental-date-picker.css" asp-append-version="true" />
    <script src="~/js/rental-date-picker.js" asp-append-version="true"></script>
    <script>
        const gameSelect = document.getElementById('GameId');
        const startDateInput = document.getElementById('StartDate');
        const endDateInput = document.getElementById('EndDate');
        const calendarContainer = document.getElementById('rentalDateCalendar');
        let rentalPicker = new RentalDatePicker(calendarContainer, {
            bookedRanges: [],
            startInput: startDateInput,
            endInput: endDateInput
        });

        async function loadBookedDates(gameId) {
            if (!gameId || gameId === '0') {
                rentalPicker.setBookedRanges([]);
                return;
            }

            const response = await fetch(`@Url.Action("BookedDates", "Requests")?gameId=${gameId}`);
            if (!response.ok) {
                rentalPicker.setBookedRanges([]);
                return;
            }

            rentalPicker.setBookedRanges(await response.json());
        }

        if (gameSelect) {
            gameSelect.addEventListener('change', () => loadBookedDates(gameSelect.value));
            if (gameSelect.value && gameSelect.value !== '0') {
                loadBookedDates(gameSelect.value);
            }
        }
    </script>
}
