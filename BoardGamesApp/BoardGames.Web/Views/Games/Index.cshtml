@model IEnumerable<GameDTO>

@{
    bool isAdmin = User.IsAdministrator();
    ViewData["Title"] = isAdmin ? "Games" : "My Games";
    bool showOwner = isAdmin && ViewBag.MineOnly != true;
    bool showMineOnlyFilter = ViewBag.ShowMineOnlyFilter == true;
    bool mineOnly = ViewBag.MineOnly == true;
}

<div class="page-header">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <div class="page-actions d-flex gap-2">
        @if (showMineOnlyFilter)
        {
            if (mineOnly)
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Show all games</a>
            }
            else
            {
                <a asp-action="Index" asp-route-mineOnly="true" class="btn btn-outline-secondary">Show only my games</a>
            }
        }
        <a asp-action="Create" class="btn btn-primary">Create Game</a>
    </div>
</div>

@if (TempData["DeleteError"] is string deleteError)
{
    <div class="alert alert-danger" role="alert">@deleteError</div>
}

@if (Model is null || !Model.Any())
{
    <div class="empty-state">
        <p>No games available.</p>
    </div>
}
else
{
    <div class="game-card-list">
@foreach (var item in Model)
{
        <div class="@(item.IsActive ? "game-card" : "game-card game-card-inactive")">
            <a class="d-flex align-items-center gap-3 flex-grow-1 text-decoration-none text-reset" asp-action="Details" asp-route-id="@item.Id">
                <div class="game-card-image-wrap">
                    <img class="game-card-image" src="@GameImageHelper.GetDisplaySource(item)" alt="@item.Name" />
                </div>

                <div class="game-card-body">
                    <div class="game-card-title-row">
                        <h2 class="game-card-title">@item.Name</h2>
                        <div class="game-card-status">
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success status-badge">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary status-badge">Inactive</span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(item.Description))
                    {
                        <p class="game-card-description">@item.Description</p>
                    }

                    <div class="game-card-meta">
                        <span>Price: @item.Price</span>
                        <span>Players: @item.MinimumPlayerNumber - @item.MaximumPlayerNumber</span>
                    </div>

                    @if (showOwner && !string.IsNullOrWhiteSpace(item.Owner?.DisplayName))
                    {
                        <div class="game-card-owner">Owner: @item.Owner.DisplayName</div>
                    }
                </div>
            </a>

            <div class="game-card-actions">
                <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </div>
        </div>
}
    </div>
}
