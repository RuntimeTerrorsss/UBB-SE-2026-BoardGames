@model GameDTO
@using BoardGames.Web.Helpers

@{
    ViewData["Title"] = Model?.Name ?? "Game Details";
    ViewData["BackUrl"] = Url.Action("Index", "Search");
    ViewData["BackText"] = "Back";
}

<partial name="_PageBack" />

<div class="game-details-header mb-4">
    <h1 class="page-title mb-1">@Model?.Name</h1>
    @if (!string.IsNullOrWhiteSpace(Model?.Owner?.DisplayName))
    {
        <p class="text-muted mb-0">@Model.Owner.DisplayName</p>
    }
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <img src="@GameImageHelper.GetDisplaySource(Model)" class="game-details-image rounded mb-4" alt="@Model?.Name" />

        <div class="game-details-section">
            <h2 class="h5 fw-semibold mb-3">Details</h2>
            <p class="text-secondary">@Model?.Description</p>
            @if (!string.IsNullOrWhiteSpace(Model?.City))
            {
                <p class="text-secondary mb-1">@Model.City</p>
            }
            <p class="text-secondary mb-1">@Model?.MinimumPlayerNumber – @Model?.MaximumPlayerNumber players</p>
            <p class="fw-semibold mb-0">@Model?.Price.ToString("0.##") RON / day</p>
        </div>
    </div>

    @if (Model?.IsActive == true)
    {
        <div class="col-lg-5">
            <div class="game-details-rental-panel">
                <h2 class="h4 fw-semibold mb-3">Request rental</h2>
                <p class="fw-semibold mb-2">Choose dates</p>

                <form asp-controller="Games" asp-action="Book" asp-route-id="@Model.Id" method="get" id="rentalRequestForm">
                    <div id="rentalDateCalendar"></div>
                    <input type="hidden" id="StartDate" name="StartDate" required />
                    <input type="hidden" id="EndDate" name="EndDate" required />

                    <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
                        <span class="fw-semibold">Estimated total</span>
                        <span class="fw-bold" id="estimatedTotal">0 RON</span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100" id="btnRequest" disabled>Send request</button>
                    <div id="availabilityMessage" class="small text-muted mt-2"></div>
                </form>
            </div>
        </div>
    }
</div>

@{
    bool canEditFromDetails = User.Identity?.IsAuthenticated == true
        && !User.IsAdministrator()
        && Model?.Owner?.Id == User.GetAccountId();
}
@if (canEditFromDetails)
{
    <div class="page-actions mt-4">
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
    </div>
}

@section Scripts {
    <link rel="stylesheet" href="~/css/rental-date-picker.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/game-details.css" asp-append-version="true" />
    <script src="~/js/rental-date-picker.js" asp-append-version="true"></script>
    <script>
		const bookedDates = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.BookedDates ?? new List<BookedDateRangeDTO>()));
		const pendingRequestDates = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PendingRequestDates ?? new List<BookedDateRangeDTO>()));
        const pricePerDay = @((Model?.Price ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
        const startDateInput = document.getElementById('StartDate');
        const endDateInput = document.getElementById('EndDate');
        const btnRequest = document.getElementById('btnRequest');
        const msgDiv = document.getElementById('availabilityMessage');
        const estimatedTotal = document.getElementById('estimatedTotal');

		const rentalPicker = new RentalDatePicker(document.getElementById('rentalDateCalendar'), {
			bookedRanges: bookedDates,
			pendingRequestRanges: pendingRequestDates,
			startInput: startDateInput,
			endInput: endDateInput,
			onChange: checkAvailability
		});

        function checkAvailability() {
            msgDiv.textContent = '';
            msgDiv.classList.remove('text-danger', 'text-success');
            btnRequest.disabled = true;
            estimatedTotal.textContent = '0 RON';

            const startVal = startDateInput.value;
            const endVal = endDateInput.value;

            if (!startVal || !endVal) {
                return;
            }

            const start = new Date(startVal + 'T00:00:00');
            const end = new Date(endVal + 'T00:00:00');

            if (start > end) {
                showError('End date cannot be earlier than the start date.');
                return;
            }

            const days = Math.floor((end - start) / (1000 * 60 * 60 * 24)) + 1;
            estimatedTotal.textContent = `${(days * pricePerDay).toFixed(2)} RON`;

			if (RentalDatePickerHelpers.rangesOverlap(start, end, bookedDates)) {
				showError('These dates are unavailable.');
				return;
			}

			if (RentalDatePickerHelpers.rangesOverlap(start, end, pendingRequestDates)) {
				showError('You already have an open request for these dates.');
				return;
			}

            showSuccess('Dates are available.');
        }

        function showError(msg) {
            msgDiv.textContent = msg;
            msgDiv.classList.remove('text-success');
            msgDiv.classList.add('text-danger');
            btnRequest.disabled = true;
        }

        function showSuccess(msg) {
            msgDiv.textContent = msg;
            msgDiv.classList.remove('text-danger');
            msgDiv.classList.add('text-success');
            btnRequest.disabled = false;
        }
    </script>
}
