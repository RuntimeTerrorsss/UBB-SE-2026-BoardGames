@model GameDTO
@using BoardGames.Web.Helpers

@{
    ViewData["Title"] = "Review rental request";
    DateTime startDate = ViewBag.StartDate;
    DateTime endDate = ViewBag.EndDate;
    int days = Math.Max(1, (int)(endDate.Date - startDate.Date).TotalDays + 1);
    decimal total = days * (Model?.Price ?? 0);
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
    </div>

    <h2 class="fw-bold mb-4">Review rental request</h2>

    @if (ViewBag.ErrorMessage is string errorMsg && !string.IsNullOrWhiteSpace(errorMsg))
    {
        <div class="alert alert-danger">@errorMsg</div>
    }

    <div class="row g-4">
        <div class="col-md-7">
            <div class="card shadow-sm mb-3">
                <div class="card-body text-center py-4">
                    <h4 class="fw-bold mb-0">@Model.Name</h4>
                </div>
            </div>

            <div class="card shadow-sm mb-3">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Date</div>
                        <div class="fw-semibold">@startDate.ToString("d MMM yyyy") &ndash; @endDate.ToString("d MMM yyyy")</div>
                    </div>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">Modify</a>
                </div>
            </div>

            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <div class="fw-semibold mb-2">Details</div>
                    <div class="d-flex justify-content-between">
                        <span>@days day@(days != 1 ? "s" : "") &times; @Model.Price.ToString("0.00") RON/day</span>
                        <span>@total.ToString("0.00") RON</span>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body d-flex justify-content-between fw-bold">
                    <span>Total</span>
                    <span>@total.ToString("0.00") RON</span>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm mb-3">
                <div class="card-body text-center">
                    <div class="fw-bold fs-5">@(Model.Owner?.DisplayName ?? "Owner")</div>
                    @if (!string.IsNullOrEmpty(Model.City))
                    {
                        <div class="text-muted small"><i class="bi bi-geo-alt-fill text-danger"></i> @Model.City</div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mb-3">
                <div class="card-body text-center">
                    <a asp-controller="Chats" asp-action="Index" class="text-decoration-none text-dark fw-semibold">Message user</a>
                </div>
            </div>

            <form asp-controller="Games" asp-action="Book" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="startDate" value="@startDate.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="endDate" value="@endDate.ToString("yyyy-MM-dd")" />
                <button type="submit" class="btn btn-primary w-100 py-3 fw-semibold">Send rental request</button>
            </form>
        </div>
    </div>
</div>
