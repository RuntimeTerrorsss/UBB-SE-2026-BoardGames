@model GameDTO

@{
    ViewData["Title"] = "Create";
    ViewData["BackUrl"] = Url.Action("Index");
}

<partial name="_PageBack" />

<div class="page-header">
    <h1 class="page-title">Create Game</h1>
</div>

<div class="form-section">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="MinimumPlayerNumber" class="form-label"></label>
            <input asp-for="MinimumPlayerNumber" class="form-control" />
            <span asp-validation-for="MinimumPlayerNumber" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="MaximumPlayerNumber" class="form-label"></label>
            <input asp-for="MaximumPlayerNumber" class="form-control" />
            <span asp-validation-for="MaximumPlayerNumber" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <input asp-for="Description" class="form-control" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Image</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>
        <div class="form-check mb-3">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="IsActive" /> @Html.DisplayNameFor(model => model.IsActive)
            </label>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create</button>
            <a class="btn btn-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
