@model BookingDTO
@using BoardGames.Shared.DTO
@{
    ViewData["Title"] = "Confirm Booking";
    DateTime startDate = (DateTime)ViewBag.StartDate;
    DateTime endDate = (DateTime)ViewBag.EndDate;
    decimal totalPrice = (decimal)ViewBag.TotalPrice;
    int totalDays = (int)ViewBag.TotalDays;
}

<style>
    .confirm-page {
        background: #f0ede8;
        min-height: 100vh;
        padding: 30px;
        font-family: 'Segoe UI', sans-serif;
    }

    .top-bar {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
    }

    .btn-back {
        background: #fff;
        border: 1px solid #ccc;
        border-radius: 6px;
        padding: 6px 14px;
        cursor: pointer;
        font-size: 14px;
        text-decoration: none;
        color: #000;
    }

    .page-title {
        font-size: 28px;
        font-weight: bold;
        margin: 0;
    }

    .main-content {
        display: grid;
        grid-template-columns: 3fr 2fr;
        gap: 24px;
        align-items: start;
    }

    .left-panel {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .section-card {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #ddd;
        overflow: hidden;
    }

    .game-banner {
        background: #e8e8e8;
        padding: 40px;
        text-align: center;
        font-size: 20px;
        font-weight: 600;
    }

    .section-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid #eee;
    }

        .section-row:last-child {
            border-bottom: none;
        }

    .section-label {
        font-weight: 600;
        font-size: 15px;
    }

    .section-value {
        color: #444;
        font-size: 14px;
    }

    .btn-modify {
        background: #fff;
        border: 1px solid #ccc;
        border-radius: 6px;
        padding: 4px 14px;
        cursor: pointer;
        font-size: 13px;
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 20px;
        font-weight: bold;
        font-size: 16px;
    }
    /* RIGHT */
    .right-panel {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .owner-card {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #ddd;
        padding: 20px;
        text-align: center;
    }

    .owner-name {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 6px;
    }

    .owner-city {
        color: #666;
        font-size: 14px;
    }

    .action-card {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #ddd;
        padding: 16px 20px;
        text-align: center;
        cursor: pointer;
        font-size: 15px;
        font-weight: 500;
        color: #000;
        text-decoration: none;
        display: block;
        transition: background 0.15s;
    }

        .action-card:hover {
            background: #f5f5f5;
        }

        .action-card.primary {
            background: #fff;
        }
</style>

<div class="confirm-page">
    <div class="top-bar">
        <a href="javascript:history.back()" class="btn-back">← Back</a>
        <h1 class="page-title">Confirm your booking</h1>
    </div>

    <div class="main-content">
        <!-- LEFT -->
        <div class="left-panel">

            <!-- Game image / banner -->
            <div class="section-card">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" style="width:100%; height:200px; object-fit:cover;" alt="@Model.Name" />
                }
                else
                {
                    <div class="game-banner">@Model.Name</div>
                }
            </div>

            <!-- Date -->
            <div class="section-card">
                <div class="section-row">
                    <div>
                        <div class="section-label">Date</div>
                        <div class="section-value">
                            @startDate.ToString("dd MMM yyyy") – @endDate.ToString("dd MMM yyyy")
                        </div>
                    </div>
                    <a href="javascript:history.back()" class="btn-modify">Modify</a>
                </div>
            </div>

            <!-- Details -->
            <div class="section-card">
                <div class="section-row">
                    <div class="section-label">Details</div>
                </div>
                <div class="section-row">
                    <div class="section-value">@totalDays days x @Model.Price RON/day</div>
                    <div class="section-value">@totalPrice.ToString("F2") RON</div>
                </div>
            </div>

            <!-- Total -->
            <div class="section-card">
                <div class="total-row">
                    <span>Total</span>
                    <span>@totalPrice.ToString("F2") RON</span>
                </div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="right-panel">
            <div class="owner-card">
                <div class="owner-name">@Model.DisplayName</div>
                <div class="owner-city">📍 @Model.City</div>
            </div>

            <a href="#" class="action-card">Message user</a>

            <form asp-action="ConfirmBooking" asp-route-id="@Model.GameId" method="post">
                <input type="hidden" name="startDate" value="@startDate.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="endDate" value="@endDate.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="confirm" value="true" />
                <button type="submit" class="action-card primary">Confirm & Pay</button>
            </form>
        </div>
    </div>
</div>