@model SearchFilterViewModel
@using Microsoft.AspNetCore.Authorization
@{
    ViewData["Title"] = "Homepage";
    var priceVal = Model.MaximumPrice.HasValue ? (int)Model.MaximumPrice.Value : 100;
    var playersVal = Model.MinimumPlayers.HasValue ? Model.MinimumPlayers.Value : 1;
    var minDate = DateTime.Today.ToString("yyyy-MM-dd");
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<style>
    .search-page {
        padding: 2rem 0;
    }

    .search-bar-card {
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 2px 16px rgba(0,0,0,0.08);
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
    }

    .form-control {
        border-radius: 0.5rem;
        border: 1.5px solid #dee2e6;
        font-size: 0.93rem;
        padding: 0.5rem 0.8rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-control:focus {
            border-color: #4361ee;
            box-shadow: 0 0 0 3px rgba(67,97,238,0.13);
        }

    .btn-primary-app {
        background: #4361ee;
        border: none;
        border-radius: 0.5rem;
        color: #fff;
        font-weight: 600;
        padding: 0.55rem 1.4rem;
        transition: background 0.2s;
    }

        .btn-primary-app:hover {
            background: #3451d1;
            color: #fff;
        }

    .btn-outline-app {
        border: 1.5px solid #4361ee;
        color: #4361ee;
        border-radius: 0.5rem;
        font-weight: 600;
        padding: 0.45rem 1rem;
        background: transparent;
        transition: all 0.2s;
        text-decoration: none;
        display: block;
        text-align: center;
    }

        .btn-outline-app:hover {
            background: #4361ee;
            color: #fff;
        }

    .filter-card {
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 2px 16px rgba(0,0,0,0.08);
        padding: 1.5rem;
        position: sticky;
        top: 1.5rem;
    }

        .filter-card h5 {
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 1.25rem;
        }

    .filter-label {
        font-weight: 600;
        font-size: 0.83rem;
        color: #343a40;
        margin-bottom: 0.3rem;
        display: block;
    }

    .game-card {
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        overflow: hidden;
        display: flex;
        height: 170px;
        transition: box-shadow 0.2s, transform 0.15s;
        text-decoration: none;
        color: inherit;
        margin-bottom: 1rem;
        position: relative;
        cursor: pointer;
    }

        .game-card:hover {
            box-shadow: 0 6px 24px rgba(67,97,238,0.13);
            transform: translateY(-2px);
            color: inherit;
        }

    .game-card .card-nav-link {
        position: absolute;
        inset: 0;
        z-index: 1;
    }

    .game-card-img {
        width: 200px;
        min-width: 200px;
        height: 170px;
        object-fit: cover;
        background: #e9ecef;
        flex-shrink: 0;
    }

    .game-card-body {
        padding: 1rem 1.25rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.35rem;
        flex: 1;
    }

        .game-card-body h6 {
            font-weight: 700;
            font-size: 1.05rem;
            color: #1a1a2e;
            margin: 0;
        }

        .game-card-body .meta {
            font-size: 0.85rem;
            color: #6c757d;
            margin: 0;
        }

            .game-card-body .meta span {
                font-weight: 600;
                color: #343a40;
            }

    .no-results {
        text-align: center;
        padding: 3rem 0;
        color: #6c757d;
    }

    .pagination .page-link {
        color: #4361ee;
        border-radius: 0.4rem;
        margin: 0 2px;
    }

    .pagination .page-item.active .page-link {
        background: #4361ee;
        border-color: #4361ee;
        color: #fff;
    }
</style>

<div class="container search-page">

    <div class="mb-3">
        <h4 class="mb-1 fw-bold" style="color:#1a1a2e">Homepage</h4>
        <p class="text-muted small mb-0">Browse available games and filter by name, location, price, and availability.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
    <div class="alert alert-danger py-2 small">@Model.ErrorMessage</div>
    }

    <form asp-controller="Search" asp-action="Filter" method="get">

        <div class="search-bar-card">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-3">
                    <label asp-for="Name" class="filter-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter game name" />
                </div>
                <div class="col-12 col-md-3">
                    <label asp-for="City" class="filter-label"></label>
                    <input asp-for="City" class="form-control" placeholder="Enter city" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="filter-label">Max price (RON/day)</label>
                    <input type="number" class="form-control" name="MaximumPrice" min="1" max="1000" step="1"
                           value="@(Model.MaximumPrice.HasValue ? ((int)Model.MaximumPrice.Value).ToString() : "")" placeholder="Any" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="filter-label">Min players</label>
                    <input type="number" class="form-control" name="MinimumPlayers" min="1" max="20" step="1"
                           value="@(Model.MinimumPlayers.HasValue ? Model.MinimumPlayers.Value.ToString() : "")" placeholder="Any" />
                </div>
                <div class="col-6 col-md-2">
                    <label asp-for="StartDate" class="filter-label"></label>
                    <input asp-for="StartDate" type="date" class="form-control" min="@minDate" />
                </div>
                <div class="col-6 col-md-2">
                    <label asp-for="EndDate" class="filter-label"></label>
                    <input asp-for="EndDate" type="date" class="form-control" min="@minDate" />
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="SortOption" class="filter-label"></label>
                    <select asp-for="SortOption" class="form-select">
                        <option value="none">Default</option>
                        <option value="price_asc">Price: lowest first</option>
                        <option value="price_desc">Price: highest first</option>
                        <option value="location">Closest to city</option>
                    </select>
                </div>
                <div class="col-12 col-md-8 d-flex gap-2 align-items-end">
                    <button type="submit" class="btn btn-primary-app">Search</button>
                    <a asp-controller="Search" asp-action="Index" class="btn-outline-app" style="width:auto;display:inline-block;padding:0.55rem 1.4rem;">Clear</a>
                </div>
            </div>
        </div>

        <input type="hidden" name="Page" id="pageInput" value="@Model.Page" />

        <div class="row g-4">
            <div class="col-12">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="fw-bold mb-0" style="color:#1a1a2e">Results</h5>
                    @if (Model.Results.Any())
                    {
                    <span class="text-muted small">Page @Model.Page of @Model.TotalPages</span>
                    }
                </div>

                @if (!Model.Results.Any())
                {
                <div class="no-results">
                    <p style="font-size:2.5rem">&#127922;</p>
                    <p class="fw-semibold mb-1">No games found</p>
                    <p class="small">Try adjusting your search or filters.</p>
                </div>
                }
                else
                {
                <div class="d-flex flex-column">
                    @foreach (var game in Model.Results)
                    {
                        var detailsUrl = isAuthenticated
                            ? Url.Action("Details", "Games", new { id = game.Id })
                            : Url.Action("Login", "Auth", new { returnUrl = Url.Action("Details", "Games", new { id = game.Id }) });
                    <div class="game-card">
                        <a class="card-nav-link" href="@detailsUrl" aria-label="View @game.Name details"></a>
                        <img class="game-card-img" src="@GameImageHelper.GetDisplaySource(game)" alt="@game.Name"
                             onerror="this.src='@GameImageHelper.PlaceholderImageSource'" />
                        <div class="game-card-body">
                            <h6>@game.Name</h6>
                            <p class="meta"><span>Price:</span> @game.Price RON/day</p>
                            <p class="meta"><span>City:</span> @game.City</p>
                            <p class="meta"><span>Players:</span> @game.MinimumPlayerNumber - @game.MaximumPlayerNumber</p>
                            @if (!string.IsNullOrWhiteSpace(game.Owner?.DisplayName))
                            {
                                <p class="meta"><span>Owner:</span> @game.Owner.DisplayName</p>
                            }
                        </div>
                    </div>
                    }
                </div>

                @if (Model.TotalPages > 1)
                    {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                            <button type="submit" class="page-link" onclick="setPage(@(Model.Page - 1))">&larr; Previous</button>
                        </li>
                        @for (int p = 1; p <= Model.TotalPages; p++)
                                {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <button type="submit" class="page-link" onclick="setPage(@p)">@p</button>
                        </li>
                                }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                            <button type="submit" class="page-link" onclick="setPage(@(Model.Page + 1))">Next &rarr;</button>
                        </li>
                    </ul>
                </nav>
                    }
                }
            </div>
        </div>
    </form>
</div>

<script>
    function setPage(page) {
        document.getElementById('pageInput').value = page;
        document.querySelector('form').submit();
    }

    document.querySelector('form').addEventListener('submit', function (e) {
        var clickedBtn = document.activeElement;
        if (clickedBtn && clickedBtn.getAttribute('onclick') && clickedBtn.getAttribute('onclick').includes('setPage')) {
            return;
        }
        document.getElementById('pageInput').value = 1;
    });
</script>
