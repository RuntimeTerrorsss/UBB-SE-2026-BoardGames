@using BoardGames.Web.Models.Search
@model SearchFilterViewModel
@{
    ViewData["Title"] = "Search Games";
    var priceVal = Model.MaximumPrice.HasValue ? (int)Model.MaximumPrice.Value : 100;
    var playersVal = Model.MinimumPlayers.HasValue ? Model.MinimumPlayers.Value : 1;
    var minDate = DateTime.Today.ToString("yyyy-MM-dd");
}

<style>
    .search-page {
        padding: 2rem 0;
    }

    .search-bar-card {
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 2px 16px rgba(0,0,0,0.08);
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
    }

    .form-control {
        border-radius: 0.5rem;
        border: 1.5px solid #dee2e6;
        font-size: 0.93rem;
        padding: 0.5rem 0.8rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-control:focus {
            border-color: #4361ee;
            box-shadow: 0 0 0 3px rgba(67,97,238,0.13);
        }

    .btn-primary-app {
        background: #4361ee;
        border: none;
        border-radius: 0.5rem;
        color: #fff;
        font-weight: 600;
        padding: 0.55rem 1.4rem;
        transition: background 0.2s;
    }

        .btn-primary-app:hover {
            background: #3451d1;
            color: #fff;
        }

    .btn-outline-app {
        border: 1.5px solid #4361ee;
        color: #4361ee;
        border-radius: 0.5rem;
        font-weight: 600;
        padding: 0.45rem 1rem;
        background: transparent;
        transition: all 0.2s;
        text-decoration: none;
        display: block;
        text-align: center;
    }

        .btn-outline-app:hover {
            background: #4361ee;
            color: #fff;
        }

    .filter-card {
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 2px 16px rgba(0,0,0,0.08);
        padding: 1.5rem;
        position: sticky;
        top: 1.5rem;
    }

        .filter-card h5 {
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 1.25rem;
        }

    .filter-label {
        font-weight: 600;
        font-size: 0.83rem;
        color: #343a40;
        margin-bottom: 0.3rem;
        display: block;
    }

    .game-card {
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        overflow: hidden;
        display: flex;
        height: 170px;
        transition: box-shadow 0.2s, transform 0.15s;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        margin-bottom: 1rem;
    }

        .game-card:hover {
            box-shadow: 0 6px 24px rgba(67,97,238,0.13);
            transform: translateY(-2px);
        }

    .game-card-img {
        width: 200px;
        min-width: 200px;
        object-fit: cover;
        background: #e9ecef;
    }

    .game-card-body {
        padding: 1rem 1.25rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.35rem;
    }

        .game-card-body h6 {
            font-weight: 700;
            font-size: 1.05rem;
            color: #1a1a2e;
            margin: 0;
        }

        .game-card-body .meta {
            font-size: 0.85rem;
            color: #6c757d;
            margin: 0;
        }

            .game-card-body .meta span {
                font-weight: 600;
                color: #343a40;
            }

    .no-results {
        text-align: center;
        padding: 3rem 0;
        color: #6c757d;
    }

    .pagination .page-link {
        color: #4361ee;
        border-radius: 0.4rem;
        margin: 0 2px;
    }

    .pagination .page-item.active .page-link {
        background: #4361ee;
        border-color: #4361ee;
        color: #fff;
    }
</style>

<div class="container search-page">

    <div class="d-flex align-items-center mb-3 gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill">
            &larr; Back
        </a>
        <h4 class="mb-0 fw-bold" style="color:#1a1a2e">Search Games</h4>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger py-2 small">@Model.ErrorMessage</div>
    }

    <form asp-controller="Search" asp-action="Filter" method="get">

        <div class="search-bar-card">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-3">
                    <label asp-for="Name" class="filter-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter game name" />
                </div>
                <div class="col-12 col-md-3">
                    <label asp-for="City" class="filter-label"></label>
                    <input asp-for="City" class="form-control" placeholder="Enter city" />
                </div>
                <div class="col-6 col-md-2">
                    <label asp-for="StartDate" class="filter-label"></label>
                    <input asp-for="StartDate" type="date" class="form-control" min="@minDate" />
                </div>
                <div class="col-6 col-md-2">
                    <label asp-for="EndDate" class="filter-label"></label>
                    <input asp-for="EndDate" type="date" class="form-control" min="@minDate" />
                </div>
                <div class="col-12 col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary-app">Search</button>
                </div>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-12 col-lg-3">
                <div class="filter-card">
                    <h5>Filters</h5>

                    <div class="mb-4">
                        <label class="filter-label">
                            Max price: <strong id="priceLabel">@(Model.MaximumPrice.HasValue ? ((int)Model.MaximumPrice.Value).ToString() : "any")</strong> RON/day
                        </label>
                        <input type="range" class="form-range" min="1" max="100" step="1"
                               id="priceRange"
                               value="@(Model.MaximumPrice.HasValue ? (int)Model.MaximumPrice.Value : 100)"
                               oninput="document.getElementById('priceLabel').textContent = this.value; document.getElementById('priceHidden').value = this.value;" />
                        <input type="hidden" id="priceHidden" name="MaximumPrice" value="@(Model.MaximumPrice.HasValue ? ((int)Model.MaximumPrice.Value).ToString() : "")" />
                    </div>

                    <div class="mb-4">
                        <label class="filter-label">
                            Min players: <strong id="playersLabel">@(Model.MinimumPlayers.HasValue? Model.MinimumPlayers.Value.ToString() : "any")</strong>
                        </label>
                        <input type="range" class="form-range" min="1" max="20" step="1"
                               id="playersRange"
                               value="@(Model.MinimumPlayers.HasValue? Model.MinimumPlayers.Value : 1)"
                               oninput="document.getElementById('playersLabel').textContent = this.value; document.getElementById('playersHidden').value = this.value;" />
                        <input type="hidden" id="playersHidden" name="MinimumPlayers" value="@(Model.MinimumPlayers.HasValue? Model.MinimumPlayers.Value.ToString() : "")" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="SortOption" class="filter-label"></label>
                        <div class="d-flex flex-column gap-2 mt-1">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="SortOption" value="none" id="sort_none"
                                       @(Model.SortOption == "none" || Model.SortOption == null ? "checked" : "") />
                                <label class="form-check-label" for="sort_none">Default</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="SortOption" value="price_asc" id="sort_asc"
                                       @(Model.SortOption == "price_asc" ? "checked" : "") />
                                <label class="form-check-label" for="sort_asc">Price: lowest first</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="SortOption" value="price_desc" id="sort_desc"
                                       @(Model.SortOption == "price_desc" ? "checked" : "") />
                                <label class="form-check-label" for="sort_desc">Price: highest first</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="SortOption" value="location" id="sort_loc"
                                       @(Model.SortOption == "location" ? "checked" : "") />
                                <label class="form-check-label" for="sort_loc">Closest to city</label>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" name="Page" id="pageInput" value="@Model.Page" />

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary-app">Apply filters</button>
                        <a asp-controller="Search" asp-action="Index" class="btn-outline-app">Clear filters</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-9">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="fw-bold mb-0" style="color:#1a1a2e">Results</h5>
                    @if (Model.Results.Any())
                    {
                        <span class="text-muted small">Page @Model.Page of @Model.TotalPages</span>
                    }
                </div>

                @if (!Model.Results.Any())
                {
                    <div class="no-results">
                        <p style="font-size:2.5rem">&#127922;</p>
                        <p class="fw-semibold mb-1">No games found</p>
                        <p class="small">Try adjusting your search or filters.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column">
                        @foreach (var game in Model.Results)
                        {
                            <a asp-controller="Games" asp-action="Details" asp-route-id="@game.GameId" class="game-card">
                                <img class="game-card-img" src="@game.Image" alt="@game.Name"
                                     onerror="this.src='/images/placeholder-game.png'" />
                                <div class="game-card-body">
                                    <h6>@game.Name</h6>
                                    <p class="meta"><span>Price:</span> @game.Price RON/day</p>
                                    <p class="meta"><span>City:</span> @game.City</p>
                                    <p class="meta"><span>Players:</span> @game.MinimumPlayerNumber - @game.MaximumPlayerNumber</p>
                                </div>
                            </a>
                        }
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-4">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                    <button type="submit" class="page-link" onclick="setPage(@(Model.Page - 1))">&larr; Previous</button>
                                </li>
                                @for (int p = 1; p <= Model.TotalPages; p++)
                                {
                                    <li class="page-item @(p == Model.Page ? "active" : "")">
                                        <button type="submit" class="page-link" onclick="setPage(@p)">@p</button>
                                    </li>
                                }
                                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                                    <button type="submit" class="page-link" onclick="setPage(@(Model.Page + 1))">Next &rarr;</button>
                                </li>
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </form>
</div>

<script>
    function setPage(page) {
        document.getElementById('pageInput').value = page;
        document.querySelector('form').submit();
    }

    document.querySelector('form').addEventListener('submit', function (e) {
        var clickedBtn = document.activeElement;
        if (clickedBtn && clickedBtn.getAttribute('onclick') && clickedBtn.getAttribute('onclick').includes('setPage')) {
            return; 
        }
        document.getElementById('pageInput').value = 1;
    });
</script>