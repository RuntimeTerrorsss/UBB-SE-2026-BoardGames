@model BoardRentAndProperty.Api.Models.Role

@{
    ViewData["Title"] = "Delete Role";
}

<div class="page-header">
    <h1 class="page-title">Delete Role</h1>
</div>

<div class="alert alert-danger delete-warning" role="alert">
    Are you sure you want to delete this role?
</div>

<dl class="row details-list">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>
</dl>

<form asp-action="Delete" data-confirm="Are you sure you want to delete this role?">
    <input type="hidden" asp-for="Id" />
    <div class="form-actions">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
