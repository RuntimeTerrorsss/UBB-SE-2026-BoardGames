@using BoardGames.Web.Models.Account
@model IEnumerable<AdminAccountViewModel>

@{
    ViewData["Title"] = "Accounts Administration";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Accounts Administration</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <em>No accounts found in the system.</em>
                        </td>
                    </tr>
                }
                
                @foreach (var account in Model)
                {
                    <tr>
                        <td><strong>@account.Username</strong></td>
                        <td>@account.Email</td>
                        <td><span class="badge bg-secondary">@account.Role?.Name</span></td>
                        
                        <td>
                            @if (account.IsSuspended)
                            {
                                <span class="badge bg-danger mb-1 d-block" style="width: fit-content;">Suspended</span>
                            }
                            else
                            {
                                <span class="badge bg-success mb-1 d-block" style="width: fit-content;">Active</span>
                            }

                            @if (account.IsLockedOut)
                            {
                                <span class="badge bg-warning text-dark d-block" style="width: fit-content;">
                                    <i class="bi bi-lock-fill"></i> Locked
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-light text-secondary border d-block" style="width: fit-content;">
                                    <i class="bi bi-unlock-fill"></i> Unlocked
                                </span>
                            }
                        </td>
                        
                        <td>
                            <div class="d-flex gap-2 justify-content-end align-items-center">
                                
                                @if (account.IsSuspended)
                                {
                                    <form asp-action="Unsuspend" method="post">
                                        <input type="hidden" name="id" value="@account.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" style="width: 85px;">
                                            Unsuspend
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Suspend" method="post" onsubmit="return confirm('Are you sure you want to suspend @account.Username?');">
                                        <input type="hidden" name="id" value="@account.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" style="width: 85px;">
                                            Suspend
                                        </button>
                                    </form>
                                }

                                @if (account.IsLockedOut)
                                {
                                    <form asp-action="Unlock" method="post">
                                        <input type="hidden" name="id" value="@account.Id" />
                                        <button type="submit" class="btn btn-sm btn-warning fw-bold" style="width: 85px;">
                                            <i class="bi bi-unlock-fill"></i> Unlock
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled style="width: 85px;">
                                        <i class="bi bi-unlock"></i> Unlocked
                                    </button>
                                }

                                <form asp-action="ResetPassword" method="post" class="d-inline-flex" onsubmit="return confirm('Are you sure you want to reset the password for @account.Username?');">
                                    <input type="hidden" name="id" value="@account.Id" />
                                    <div class="input-group input-group-sm" style="max-width: 250px;">
                                        <input type="text" name="newPassword" class="form-control" placeholder="New password" required minlength="6" autocomplete="off" />
                                        <button type="submit" class="btn btn-primary">
                                            Reset
                                        </button>
                                    </div>
                                </form>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>