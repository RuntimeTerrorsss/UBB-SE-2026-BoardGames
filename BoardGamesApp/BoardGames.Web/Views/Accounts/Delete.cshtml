@model BoardRentAndProperty.Api.Models.Account

@{
    ViewData["Title"] = "Delete Account";
}

<div class="page-header">
    <h1 class="page-title">Delete Account</h1>
</div>

<div class="alert alert-danger delete-warning" role="alert">
    Are you sure you want to delete this account?
</div>

<dl class="row details-list">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DisplayName)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.DisplayName)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Username)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Username)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PasswordHash)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.PasswordHash)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PhoneNumber)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.PhoneNumber)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.AvatarUrl)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.AvatarUrl)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IsSuspended)</dt>
    <dd class="col-sm-9">
        @if (Model.IsSuspended)
        {
            <span class="badge bg-danger status-badge">Suspended</span>
        }
        else
        {
            <span class="badge bg-success status-badge">Active</span>
        }
    </dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedAt)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.UpdatedAt)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.UpdatedAt)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Country)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Country)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.City)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.City)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.StreetName)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.StreetName)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.StreetNumber)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.StreetNumber)</dd>
</dl>

<form asp-action="Delete" data-confirm="Are you sure you want to delete this account?">
    <input type="hidden" asp-for="Id" />
    <div class="form-actions">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
