@using BoardGames.Web.Models.Account
@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<style>
    .register-wrapper {
        min-height: calc(100vh - 160px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 0;
    }

    .register-card {
        background: #fff;
        border: none;
        border-radius: 1rem;
        box-shadow: 0 4px 32px rgba(0, 0, 0, 0.10);
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 520px;
    }

    .register-card h2 {
        font-weight: 700;
        letter-spacing: -0.5px;
        color: #1a1a2e;
        margin-bottom: 0.2rem;
    }

    .register-card .subtitle {
        color: #6c757d;
        font-size: 0.92rem;
        margin-bottom: 1.75rem;
    }

    .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #adb5bd;
        margin: 1.4rem 0 0.75rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: #343a40;
        margin-bottom: 0.3rem;
    }

    .form-control {
        border-radius: 0.5rem;
        border: 1.5px solid #dee2e6;
        font-size: 0.95rem;
        padding: 0.55rem 0.85rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus {
        border-color: #4361ee;
        box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.13);
    }

    .password-wrapper {
        position: relative;
    }

    .btn-register {
        background: #4361ee;
        border: none;
        border-radius: 0.5rem;
        color: #fff;
        font-weight: 600;
        font-size: 1rem;
        padding: 0.65rem;
        width: 100%;
        margin-top: 0.5rem;
        transition: background 0.2s, transform 0.1s;
    }

    .btn-register:hover { background: #3451d1; color: #fff; }
    .btn-register:active { transform: scale(0.99); }
    .btn-register:disabled { background: #7c93f3; cursor: not-allowed; }

    .divider {
        border: none;
        border-top: 1.5px solid #f1f3f5;
        margin: 1.5rem 0 1rem;
    }

    .login-link {
        text-align: center;
        font-size: 0.88rem;
        color: #6c757d;
    }

    .login-link a {
        color: #4361ee;
        font-weight: 600;
        text-decoration: none;
    }

    .login-link a:hover { text-decoration: underline; }
</style>

<div class="register-wrapper">
    <div class="register-card">

        <h2>Create an account</h2>

        <form id="registerForm" asp-controller="Account" asp-action="Register" method="post" novalidate>
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
            {
                <div class="alert alert-danger py-2 small">
                    @Html.ValidationSummary(true)
                </div>
            }

            <div class="section-label">Account</div>

            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="Username" class="form-label">Username</label>
                    <input asp-for="Username" class="form-control" placeholder="Enter username" autocomplete="username" />
                    <span asp-validation-for="Username" class="text-danger small d-block"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="DisplayName" class="form-label">Display Name</label>
                    <input asp-for="DisplayName" class="form-control" placeholder="Enter display name" />
                    <span asp-validation-for="DisplayName" class="text-danger small d-block"></span>
                </div>
            </div>

            <div class="mt-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small d-block"></span>
            </div>

            <div class="section-label">Password</div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <div class="password-wrapper">
                    <input asp-for="Password" type="password" class="form-control"
                           id="passwordInput" placeholder="Min. 6 characters" autocomplete="new-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small d-block"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <div class="password-wrapper">
                    <input asp-for="ConfirmPassword" type="password" class="form-control"
                           id="confirmPasswordInput" placeholder="Repeat your password" autocomplete="new-password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small d-block"></span>
            </div>

            <div class="section-label">Location</div>

            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="City" class="form-label">City</label>
                    <input asp-for="City" class="form-control" placeholder="e.g. Cluj-Napoca" />
                    <span asp-validation-for="City" class="text-danger small d-block"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Country" class="form-label">Country</label>
                    <input asp-for="Country" class="form-control" placeholder="e.g. Romania" />
                    <span asp-validation-for="Country" class="text-danger small d-block"></span>
                </div>
            </div>

            <hr class="divider" />

            <button type="submit" class="btn btn-register" id="submitBtn">
                Create account
            </button>
        </form>

        <p class="login-link mt-3">
            Already have an account? <a asp-controller="Account" asp-action="Login">Sign in</a>
        </p>

    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(function () {
            // Disable submit button on valid submit
            $("#registerForm").on("submit", function () {
                if ($(this).valid()) {
                    $("#submitBtn").prop("disabled", true).text("Creating account…");
                }
            });

        });
    </script>
}
