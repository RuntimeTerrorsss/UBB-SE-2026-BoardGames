@using BoardGames.Shared.DTO
@{
    ViewData["Title"] = "Cash Payment";
    var rental = (RentalDTO)ViewBag.Rental;
    int messageId = ViewBag.MessageId;
}

<link rel="stylesheet" href="~/css/rentals.css" asp-append-version="true" />

<div class="rentals-page">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-3">@TempData["Error"]</div>
    }

    <h2 class="rentals-title">Cash payment</h2>
    <p class="rentals-subtitle mb-4">
        Confirm cash payment for <strong>@rental.GameName</strong> (@rental.StartDate:dd MMM yyyy – @rental.EndDate:dd MMM yyyy).
        Total: <strong>@rental.Price.ToString("C")</strong>
    </p>

    <form asp-action="ConfirmCashPayment" method="post" class="border rounded-3 p-4 bg-white shadow-sm" style="max-width: 480px;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="rentalId" value="@rental.Id" />
        <input type="hidden" name="messageId" value="@messageId" />

        <p class="small text-muted mb-3">
            This records a cash payment agreement in chat. Coordinate handover with the owner in Messages.
        </p>

        <button type="submit" class="btn btn-primary w-100">Confirm cash payment</button>
        <a asp-action="Checkout" asp-route-rentalId="@rental.Id" asp-route-messageId="@messageId"
           class="btn btn-outline-secondary w-100 mt-2">Back</a>
    </form>
</div>
