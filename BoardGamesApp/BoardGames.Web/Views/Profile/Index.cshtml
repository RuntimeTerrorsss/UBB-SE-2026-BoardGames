@using BoardGames.Web.Models.Account
@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row mt-4">
        <div class="col-md-4 text-center mb-4">
            <div class="card p-3 shadow-sm">
                @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                {
                    <img src="@Model.AvatarUrl" alt="Avatar" class="rounded-circle img-fluid mb-3" style="width: 150px; height: 150px; object-fit: cover;" />
                }
                else
                {
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 150px; height: 150px;">
                        <span class="text-white fs-1">@Model.DisplayName?.FirstOrDefault()</span>
                    </div>
                }

                @* Formularul de Upload cu input ascuns *@
                <form id="avatarForm" asp-controller="Profile" asp-action="UploadAvatar" enctype="multipart/form-data" method="post" class="mb-2">
                    @Html.AntiForgeryToken()
                    <input type="file" id="AvatarFileHidden" name="AvatarFile" style="display:none" accept=".jpg,.jpeg,.png" />
                    
                    <button type="button" class="btn btn-primary w-100 mb-2" onclick="document.getElementById('AvatarFileHidden').click();">
                        Upload Picture
                    </button>
                </form>

                <form asp-controller="Profile" asp-action="RemoveAvatar" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100">Remove Picture</button>
                </form>
            </div>

            <div class="mt-3">
                <a asp-controller="Profile" asp-action="ChangePassword" class="btn btn-warning w-100">Security / Change Password</a>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card p-4 shadow-sm">
                <form asp-controller="Profile" asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    @* Adaugam campul hidden pentru a pastra URL-ul pozei la re-randare in caz de eroare *@
                    <input type="hidden" asp-for="AvatarUrl" />
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Username" class="form-label"></label>
                            <input asp-for="Username" class="form-control bg-light" readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DisplayName" class="form-label"></label>
                            <input asp-for="DisplayName" class="form-control" />
                            <span asp-validation-for="DisplayName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="StreetName" class="form-label"></label>
                            <input asp-for="StreetName" class="form-control" />
                            <span asp-validation-for="StreetName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StreetNumber" class="form-label"></label>
                            <input asp-for="StreetNumber" class="form-control" />
                            <span asp-validation-for="StreetNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="City" class="form-label"></label>
                            <input asp-for="City" class="form-control" />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Country" class="form-label"></label>
                            <input asp-for="Country" class="form-control" />
                            <span asp-validation-for="Country" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-success px-4">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('AvatarFileHidden').addEventListener('change', function() {
            if (this.files && this.files.length > 0) {
                document.getElementById('avatarForm').submit();
            }
        });
    </script>
}