@model IReadOnlyList<BoardRentAndProperty.Contracts.DataTransferObjects.NotificationDTO>

@{
    ViewData["Title"] = "My Notifications";

    int totalNotificationCount = (int)(ViewData["TotalCount"] ?? 0);
    int currentPageIndex = (int)(ViewData["CurrentPage"] ?? 1);
    int pageSizeLimit = (int)(ViewData["PageSize"] ?? 3);

    int totalPageCount = (int)Math.Ceiling((double)totalNotificationCount / pageSizeLimit);
    if (totalPageCount == 0)
    {
        totalPageCount = 1;
    }

    int startItemIndex = totalNotificationCount == 0 ? 0 : ((currentPageIndex - 1) * pageSizeLimit) + 1;
    int endItemIndex = Math.Min(startItemIndex + Model.Count - 1, totalNotificationCount);
}

<style>
    .notification-circle {
        width: 50px;
        height: 50px;
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
    }

    .notification-icon {
        color: #6c757d;
    }
</style>

<div class="container">
    <h2 class="fw-bold mb-4">@ViewData["Title"]</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info border-0 shadow-sm">
            You do not have any notifications yet.
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var notification in Model)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center">

                        <div class="flex-shrink-0 me-3">
                            <div class="notification-circle rounded-circle d-flex align-items-center justify-content-center shadow-sm">
                                <i class="bi bi-bell-fill fs-5 notification-icon"></i>
                            </div>
                        </div>

                        <div class="flex-grow-1">
                            <h5 class="fw-bold mb-1">@notification.Title</h5>
                            <p class="text-muted mb-1">@notification.Body</p>
                            <small class="text-secondary d-block">@notification.TimeDisplay</small>
                        </div>

                        <div class="ms-3">
                            <form asp-action="Delete" asp-route-id="@notification.Id" method="post" onsubmit="return confirm('Delete this notification?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                    Delete
                                </button>
                            </form>
                        </div>

                    </div>
                </div>
            }
        </div>

        <div class="mt-5 d-flex justify-content-between align-items-center border-top pt-3">
            <div class="text-muted small">
                Showing <strong>@startItemIndex-@endItemIndex</strong> of <strong>@totalNotificationCount</strong>
            </div>

            <div class="d-flex align-items-center gap-2">
                <a asp-action="Index" asp-route-page="@(currentPageIndex - 1)"
                   class="btn btn-dark btn-sm px-3 @(currentPageIndex <= 1 ? "disabled" : "")">
                    Previous
                </a>

                <span class="mx-2 small fw-bold">@currentPageIndex / @totalPageCount</span>

                <a asp-action="Index" asp-route-page="@(currentPageIndex + 1)"
                   class="btn btn-dark btn-sm px-3 @(currentPageIndex >= totalPageCount ? "disabled" : "")">
                    Next
                </a>
            </div>
        </div>
    }
</div>