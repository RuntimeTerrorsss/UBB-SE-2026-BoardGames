<Page
    x:Class="BoardGames.Desktop.Views.DeliveryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="20">
        <StackPanel MaxWidth="1000" Spacing="12" HorizontalAlignment="Center" >
            <StackPanel.Resources>
                <Style TargetType="TextBox">
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="MinWidth" Value="600"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>

                <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
                    <Setter Property="Foreground" Value="Red"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Margin" Value="4,0,0,0"/>
                </Style>
            </StackPanel.Resources>
            
            <TextBlock Text="Delivery Address"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Margin="0,0,0,8"/>
            
            
            <StackPanel Spacing="4">
                <TextBox x:Name="CountryInput"
                         PlaceholderText="Country"
                         Tag="Country"
                         TextChanged="OnFieldChanged"/>
                <TextBlock x:Name="CountryError"
                           Foreground="Red" FontSize="20"
                           Visibility="Collapsed"/>
            </StackPanel>

            
            <StackPanel Spacing="4">
                <TextBox x:Name="CityInput"
                         PlaceholderText="City"
                         Tag="City"
                         TextChanged="OnFieldChanged"/>
                <TextBlock x:Name="CityError"
                           Foreground="Red" FontSize="20"
                           Visibility="Collapsed"/>
            </StackPanel>

            
            <StackPanel Spacing="4">
                <TextBox x:Name="StreetInput"
                         PlaceholderText="Street"
                         Tag="Street"
                         TextChanged="OnFieldChanged"/>
                <TextBlock x:Name="StreetError"
                           Foreground="Red" FontSize="20"
                           Visibility="Collapsed"/>
            </StackPanel>

            
            <StackPanel Spacing="4">
                <TextBox x:Name="StreetNumberInput"
                         PlaceholderText="Street Number"
                         Tag="StreetNumber"
                         TextChanged="OnFieldChanged"/>
                <TextBlock x:Name="StreetNumberError"
                           Foreground="Red" FontSize="20"
                           Visibility="Collapsed"/>
            </StackPanel>

            
            <Button Content="ðŸ“ Set location on map"
                    Click="OnOpenMapClicked"
                    HorizontalAlignment="Stretch"/>

            
            <CheckBox Content="Save address for future orders"
                      Checked="OnSaveAddressChecked"
                      Unchecked="OnSaveAddressUnchecked"/>
            <StackPanel Spacing="8" Margin="0,10,0,10">
                <TextBlock Text="Select Payment Method:" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <RadioButton x:Name="CardPaymentRadio" Content="Card" IsChecked="True"/>
                    <RadioButton x:Name="CashPaymentRadio" Content="Cash"/>
                </StackPanel>
            </StackPanel>
            
            
            <Button Content="Submit Address &amp; Continue to Payment"
                    Click="OnSubmitClicked"
                    Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"/>

            
            <Border x:Name="MapOverlay"
                    Visibility="Collapsed"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="400"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <WebView2 x:Name="MapWebView" Grid.Row="0"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8" Margin="8">
                        <Button Content="Cancel"
                                Click="OnCloseMapClicked"/>
                        <Button Content="Confirm location"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="OnConfirmLocationClicked"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
