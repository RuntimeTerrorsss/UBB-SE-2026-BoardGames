<Page
    x:Class="BoardGames.Desktop.Views.GameDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BoardGames.Desktop.Views"
    xmlns:converters="using:BoardGames.Desktop.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
    </Page.Resources>

    <Grid Padding="30,50,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Back"
                    Click="OnBackClicked"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding GameDetails.Name}"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Grid>

        <InfoBar Grid.Row="1"
                 Title="Error"
                 Message="Could not retrieve listing details. Please try again later."
                 Severity="Error"
                 IsOpen="{Binding HasError}"
                 Margin="0,0,0,12"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">

                        <Border Grid.Column="0"
                                Width="220"
                                Height="180"
                                CornerRadius="10">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding GameDetails.Image, Converter={StaticResource StringToImageSourceConverter}}"
                                            Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="📍" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding GameDetails.City}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="👥" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="{Binding GameDetails.MinimumPlayerNumber}"/>
                                    <Run Text=" – "/>
                                    <Run Text="{Binding GameDetails.MaximumPlayerNumber}"/>
                                    <Run Text=" players"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="💰" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="{Binding GameDetails.Price}"/>
                                    <Run Text=" RON/day"/>
                                </TextBlock>
                            </StackPanel>

                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Description"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding GameDetails.Description}"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <StackPanel Spacing="10">

                        <TextBlock Text="Owner's profile"
                                   FontSize="16"
                                   FontWeight="Bold"/>

                        <Border Width="60" Height="60" CornerRadius="30" HorizontalAlignment="Left">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding GameDetails.OwnerAvatarUrl, Converter={StaticResource StringToImageSourceConverter}}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <TextBlock Text="{Binding GameDetails.OwnerName}"
                                   FontWeight="SemiBold"/>

                        <Button Content="Chat with owner"
                                Command="{Binding ChatWithOwnerCommand}"/>

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">

                    <Border CornerRadius="12"
                            Padding="20"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                        <StackPanel Spacing="16">

                            <TextBlock Text="Book this game"
                                       FontSize="20"
                                       FontWeight="Bold"/>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock FontSize="22" FontWeight="Bold">
                                    <Run Text="{Binding GameDetails.Price}"/>
                                    <Run Text="RON"/>
                                </TextBlock>
                                <TextBlock Text="/ day"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,3"/>
                            </StackPanel>

                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <TextBlock Text="Choose dates" FontWeight="SemiBold"/>

                            <CalendarView x:Name="RentalCalendar"
                                          SelectionMode="Multiple"
                                          HorizontalAlignment="Stretch"
                                          MinDate="{Binding Today}"
                                          SelectedDatesChanged="OnDatesChanged"
                                          CalendarViewDayItemChanging="OnDayItemChanging"/>

                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="12" Height="12" Fill="Red" VerticalAlignment="Center"/>
                                    <TextBlock Text="Unavailable" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="12" Height="12" Fill="Green" VerticalAlignment="Center"/>
                                    <TextBlock Text="Available" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Total price"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center">
                                    <Run Text="{Binding TotalPrice}"/>
                                    <Run Text=" RON"/>
                                </TextBlock>
                            </Grid>

                            <Button Content="Book now"
                                    Click="OnBookClicked"
                                    HorizontalAlignment="Stretch"
                                    FontSize="16"
                                    Padding="0,12"/>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Page>