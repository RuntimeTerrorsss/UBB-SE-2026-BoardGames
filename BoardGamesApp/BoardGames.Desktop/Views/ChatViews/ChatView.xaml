<?xml version="1.0" encoding="utf-8" ?>
<UserControl
	x:Class="BoardGames.Desktop.Views.ChatViews.ChatView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:BoardGames.Desktop.Views.ChatViews"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            
            <RowDefinition Height="Auto" />
            
            <RowDefinition Height="*" />
            
            <RowDefinition Height="Auto" />
            
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        
        <Border
			Grid.Row="0"
			Padding="16,12"
			Background="{ThemeResource LayerFillColorDefaultBrush}"
			BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
			BorderThickness="0,0,0,1">
            <StackPanel
				VerticalAlignment="Center"
				Orientation="Horizontal"
				Spacing="12">
                
                <PersonPicture
					x:Name="AvatarPicture"
					Width="40"
					Height="40" />
                
                <TextBlock
					x:Name="BannerDisplayName"
					VerticalAlignment="Center"
					FontSize="16"
					FontWeight="SemiBold"
					Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>
        </Border>

        
        <ScrollViewer
			x:Name="ScrollContainer"
			Grid.Row="1"
			Padding="16,12"
			VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MessagesPanel" Spacing="4" />
        </ScrollViewer>

        
        <Border
			x:Name="ImagePreviewPanel"
			Grid.Row="2"
			Padding="12,8"
			Background="{ThemeResource LayerFillColorDefaultBrush}"
			BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
			BorderThickness="0,1,0,0"
			Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    
                    <ColumnDefinition Width="Auto" />
                    
                    <ColumnDefinition Width="*" />
                    
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                
                <Border
					Grid.Column="0"
					CornerRadius="6">
                    <Image
						x:Name="ImagePreview"
						MaxHeight="80"
						MaxWidth="120"
						Stretch="Uniform" />
                </Border>

                
                <TextBlock
					Grid.Column="1"
					VerticalAlignment="Center"
					FontSize="13"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					Text="Image ready to send" />

                
                <Button
					x:Name="RemoveImageButton"
					Grid.Column="2"
					Width="32"
					Height="32"
					Padding="0"
					Background="Transparent"
					Click="RemoveImageButton_Click"
					ToolTipService.ToolTip="Remove image">
                    <FontIcon FontSize="14" Glyph="&#xE711;" />
                </Button>
            </Grid>
        </Border>

        
        <Border
			Grid.Row="3"
			Padding="12,10"
			Background="{ThemeResource LayerFillColorDefaultBrush}"
			BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
			BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    
                    <ColumnDefinition Width="Auto" />
                    
                    <ColumnDefinition Width="*" />
                    
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                
                <Button
					x:Name="AttachImageButton"
					Grid.Column="0"
					Width="40"
					Height="40"
					Padding="0"
					Background="Transparent"
                    Click="AttachImageButton_Click"
					ToolTipService.ToolTip="Attach image">
                    <FontIcon FontSize="18" Glyph="&#xE723;" />
                </Button>

                
                <TextBox
					x:Name="MessageInput"
					Grid.Column="1"
					VerticalAlignment="Center"
					AcceptsReturn="False"
					CornerRadius="8"
					MaxLength="512"
					Paste="MessageInput_Paste"
					PlaceholderText="Type a messageâ€¦"
					Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
					TextWrapping="Wrap" />
                

                
                <Button
					x:Name="SendButton"
					Grid.Column="2"
					Width="40"
					Height="40"
					Padding="0"
					Click="SendButton_Click"
					Style="{StaticResource AccentButtonStyle}"
					ToolTipService.ToolTip="Send">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Enter" />
                    </Button.KeyboardAccelerators>
                    <FontIcon FontSize="16" Glyph="&#xE724;" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>