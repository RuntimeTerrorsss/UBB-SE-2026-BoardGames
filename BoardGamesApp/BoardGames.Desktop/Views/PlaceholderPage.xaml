<Page
    x:Class="BoardGames.Desktop.Views.PlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32">
        <StackPanel MaxWidth="720" Spacing="18">
            <TextBlock x:Name="TitleText" FontSize="36" FontWeight="Bold" />
            <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" FontSize="18" />
            <TextBlock Text="This page is intentionally a Task 8 placeholder. Feature integration continues in Tasks 9 and 10."
                       Foreground="Gray"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Page>
