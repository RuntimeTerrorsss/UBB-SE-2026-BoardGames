<Page
    x:Class="BookingBoardGames.Src.Views.Test.FeedTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BookingBoardGames.Src.Views.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Padding="24" Spacing="20">

            <!-- Title -->
            <TextBlock
                Text="Recommended Games"
                FontSize="28"
                FontWeight="Bold"/>

            <!-- Feed -->
            <ItemsControl x:Name="GamesFeed">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="16"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <controls:GameCard
                            GameId="{Binding GameId}"
                            Title="{Binding Title}"
                            Location="{Binding Location}"
                            PlayersText="{Binding PlayersText}"
                            PriceText="{Binding PriceText}"
                            ImageSource="{Binding ImageSource}" />

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </StackPanel>

    </ScrollViewer>

</Page>