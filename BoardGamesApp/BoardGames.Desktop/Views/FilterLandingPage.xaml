<Page
    x:Class="BoardGames.Desktop.Views.FilterLandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <Grid Padding="32">
            <StackPanel MaxWidth="720" Spacing="18">
                <TextBlock Text="Search Games" FontSize="42" FontWeight="Bold" />
                <TextBlock x:Name="StatusText" TextWrapping="Wrap" FontSize="18" />
                <TextBlock Text="This is the Task 8 landing route. Real search and game details integration continues in Task 9."
                           TextWrapping="Wrap"
                           Foreground="Gray" />
                <Button x:Name="LoginButton"
                        Content="Login"
                        HorizontalAlignment="Left"
                        Click="LoginButton_Click" />

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
