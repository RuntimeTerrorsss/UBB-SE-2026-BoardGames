<Page
    x:Class="BookingBoardGames.Src.Views.Pages.FeedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BookingBoardGames.Src.Views.Controls">

    <Grid Padding="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SEARCH BAR -->
        <Border
            Grid.Row="0"
            CornerRadius="30"
            BorderBrush="LightGray"
            BorderThickness="1"
            Padding="10"
            HorizontalAlignment="Center">

            <Grid ColumnSpacing="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- GAME NAME -->
                <StackPanel>
                    <TextBlock Text="Game" FontSize="12" FontWeight="Bold"/>
                    <TextBox
                x:Name="GameSearchBox"
                PlaceholderText="filter games"/>
                </StackPanel>

                <!-- WHERE -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Where" FontSize="12" FontWeight="Bold"/>
                    <TextBox
                x:Name="CitySearchBox"
                PlaceholderText="filter city"/>
                </StackPanel>

                <!-- WHEN (CALENDAR) -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="When" FontSize="12" FontWeight="Bold"/>
                    <DatePicker
                x:Name="DateSearchPicker"/>
                </StackPanel>

                <!-- SEARCH BUTTON -->
                <Button
                    Grid.Column="3"
                    Width="45"
                    Height="45"
                    CornerRadius="22"
                    Background="Red">

                    <SymbolIcon Symbol="Find"/>

                </Button>

            </Grid>

        </Border>

        <!-- TITLE -->
        <TextBlock
            Grid.Row="1"
            Text="Recommended Games"
            FontSize="28"
            FontWeight="Bold"
            HorizontalAlignment="Left"
            Margin="0,20,0,20"/>


        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2" ColumnSpacing="30">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel
                x:Name="EmptyStatePanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="10"
                Visibility="Collapsed">

                <TextBlock
                    Text="No games available"
                    FontSize="20"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"/>

                <TextBlock
                    Text="Try another search"
                    FontSize="14"
                    Opacity="0.7"
                    HorizontalAlignment="Center"/>

            </StackPanel>

            <!-- FILTER PANEL -->
            <Border
                Grid.Column="0"
                Padding="16"
                CornerRadius="8"
                BorderBrush="Gray"
                BorderThickness="1">

                <StackPanel Spacing="16">

                    <TextBlock
                        Text="Filters"
                        FontSize="20"
                        FontWeight="Bold"/>

                    <!-- Price slider -->
                    <TextBlock Text="Price per day"/>
                    <Slider
                        x:Name="PriceSlider"
                        Minimum="0"
                        Maximum="100"/>

                    <!-- Players slider -->
                    <TextBlock Text="Number of players"/>
                    <Slider
                        x:Name="PlayersSlider"
                        Minimum="1"
                        Maximum="12"/>

                    <TextBlock
                        Text="Sort by"
                        FontWeight="Bold"
                        Margin="0,10,0,0"/>

                    <RadioButtons>

                        <x:String>Price: lowest to highest</x:String>
                        <x:String>Price: highest to lowest</x:String>

                    </RadioButtons>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <Button
                            x:Name="ApplyFiltersButton"
                            Content="Apply Filters"/>

                        <Button
                            x:Name="ClearFiltersButton"
                            Content="Clear Filters"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- FEED -->
            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- SCROLLABLE GAME LIST -->
                <ScrollViewer Grid.Row="0">

                    <ItemsControl x:Name="GamesFeed">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="16"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <controls:GameCard
                                    GameId="{Binding GameId}"
                                    Title="{Binding Title}"
                                    Location="{Binding Location}"
                                    PlayersText="{Binding PlayersText}"
                                    PriceText="{Binding PriceText}"
                                    ImageSource="{Binding ImageSource}"/>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </ScrollViewer>

                <!-- PAGINATION -->
                <StackPanel
                    Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="20"
                    Margin="0,20,0,0">

                    <Button
                        x:Name="PreviousPageButton"
                        Content="Previous"
                        IsEnabled="False"/>

                    <TextBlock
                        x:Name="CurrentPageText"
                        Text="Page 1 of 5"
                        VerticalAlignment="Center"
                        FontWeight="Bold"/>

                    <Button
                        x:Name="NextPageButton"
                        Content="Next"/>

                </StackPanel>

            </Grid>

        </Grid>

    </Grid>

</Page>