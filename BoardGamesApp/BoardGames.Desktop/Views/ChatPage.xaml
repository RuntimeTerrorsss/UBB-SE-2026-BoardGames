<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BoardGames.Desktop.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BoardGames.Desktop.Views">
    <Page.Resources>
        <local:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter" />
        <local:BoolToBubbleColorConverter x:Key="BoolToBubbleColorConverter" />
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Chat" FontSize="28" FontWeight="SemiBold" />
            <TextBlock x:Name="StatusText" Foreground="Gray" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView x:Name="ConversationsList"
                      Grid.Column="0"
                      SelectionChanged="ConversationsList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="8" Spacing="4">
                            <TextBlock Text="{Binding OtherUserName}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LastMessagePreview}" Foreground="Gray" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ListView x:Name="MessagesList" Grid.Column="1">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">

                            
                            <StackPanel HorizontalAlignment="{Binding IsCurrentUser, Converter={StaticResource BoolToAlignmentConverter}}"
                                        MaxWidth="360" Spacing="2"
                                        Visibility="{Binding IsRentalRequest, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                <TextBlock Text="{Binding SenderLabel}" FontSize="11" FontWeight="SemiBold" Foreground="Gray" />
                                <Border Padding="10,8" CornerRadius="8"
                                        Background="{Binding IsCurrentUser, Converter={StaticResource BoolToBubbleColorConverter}}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SentAtDisplay}" FontSize="11" Foreground="Gray" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            
                            <Border Padding="16" CornerRadius="8" Background="#1A2840"
                                    BorderBrush="#2A3F60" BorderThickness="1" MaxWidth="420"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding IsRentalRequest, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="ðŸ—“" FontSize="16" VerticalAlignment="Center" />
                                        <TextBlock Text="Rental Request" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Opacity="0.85" />
                                    <TextBlock Text="{Binding SentAtDisplay}" FontSize="11" Foreground="Gray" />
                                    
                                    <Border Background="#CA8A04" CornerRadius="4" Padding="8,4"
                                            Visibility="{Binding ShowAwaitingBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Awaiting owner response" Foreground="White"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center" FontSize="12" />
                                    </Border>

                                    <Border Background="#2563EB" CornerRadius="4" Padding="8,4"
                                            Visibility="{Binding ShowPendingPaymentBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Pending payment" Foreground="White"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center" FontSize="12" />
                                    </Border>

                                    <Border Background="#16A34A" CornerRadius="4" Padding="8,4"
                                            Visibility="{Binding ShowCompletedBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Rental completed ✓" Foreground="White"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center" FontSize="12" />
                                    </Border>
                               
                                    <Border Background="#DC2626" CornerRadius="4" Padding="8,4"
                                            Visibility="{Binding ShowDeclinedBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Request declined" Foreground="White"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center" FontSize="12" />
                                    </Border>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                Visibility="{Binding ShowOwnerActions, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button Tag="{Binding}" Click="AcceptRequest_Click"
                                                Content="Accept" Style="{StaticResource AccentButtonStyle}" />
                                        <Button Tag="{Binding}" Click="DeclineRequest_Click"
                                                Content="Decline" />
                                    </StackPanel>
                                    
                                    <Button Tag="{Binding}" Click="CancelRequest_Click"
                                            Content="Cancel request"
                                            Visibility="{Binding ShowRenterCancel, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <Button Tag="{Binding}" Click="ProceedToPayment_Click"
                                            Content="Proceed to payment"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Visibility="{Binding ShowProceedToPayment, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>

                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="MessageTextBox"
                     PlaceholderText="Type a message"
                     MaxLength="512" />
            <Button Grid.Column="1"
                    Content="Send"
                    Click="SendButton_Click" />
        </Grid>
    </Grid>
</Page>
