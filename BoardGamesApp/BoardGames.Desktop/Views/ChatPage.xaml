<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BoardGames.Desktop.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Chat" FontSize="28" FontWeight="SemiBold" />
            <TextBlock x:Name="StatusText" Foreground="Gray" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView x:Name="ConversationsList"
                      Grid.Column="0"
                      SelectionChanged="ConversationsList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="8" Spacing="4">
                            <TextBlock Text="{Binding Id}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding MessageList.Count}" Foreground="Gray" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ListView x:Name="MessagesList" Grid.Column="1">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="12" BorderBrush="LightGray" BorderThickness="1" CornerRadius="6">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SentAt}" FontSize="12" Foreground="Gray" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="MessageTextBox"
                     PlaceholderText="Type a message"
                     MaxLength="512" />
            <Button Grid.Column="1"
                    Content="Send"
                    Click="SendButton_Click" />
        </Grid>
    </Grid>
</Page>
