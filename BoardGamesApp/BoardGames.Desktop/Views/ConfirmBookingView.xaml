<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BoardGames.Desktop.Views.ConfirmBookingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BoardGames.Desktop.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="30,50,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR: Back + Title -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Back"
                    Click="OnBackClicked"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"/>

            <TextBlock Grid.Column="1"
                       Text="Confirm your booking"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT SIDE ===== -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">

                    <!-- Game image + name -->
                    <Border CornerRadius="12"
                            Padding="16"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                            <Border Grid.Column="0"
                                    Width="120"
                                    Height="90"
                                    CornerRadius="8">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding GameImage}" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding GameAndUserDetails.Name}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Date section -->
                    <Border CornerRadius="12"
                            Padding="16"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Date"
                                           FontWeight="Bold"
                                           FontSize="16"/>
                                <TextBlock FontSize="14">
                                    <Run Text="{Binding StartDate}"/>
                                    <Run Text=" – "/>
                                    <Run Text="{Binding EndDate}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Modify"
                                    Click="OnModifyClicked"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Details section -->
                    <Border CornerRadius="12"
                            Padding="16"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Details"
                                       FontWeight="Bold"
                                       FontSize="16"/>

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0">
                                    <Run Text="{Binding NumberOfDays}"/>
                                    <Run Text=" days x "/>
                                    <Run Text="{Binding GameAndUserDetails.Price}"/>
                                    <Run Text=" RON/day"/>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           FontWeight="SemiBold">
                                    <Run Text="{Binding TotalPrice}"/>
                                    <Run Text=" RON"/>
                                </TextBlock>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Total -->
                    <Border CornerRadius="12"
                            Padding="16"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Total"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding TotalPrice}"/>
                                <Run Text=" RON"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== RIGHT SIDE ===== -->
            <StackPanel Grid.Column="2" Spacing="20" VerticalAlignment="Top">

                <!-- Owner card -->
                <Border CornerRadius="12"
                        Padding="16"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">

                        <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding OwnerImage}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="{Binding GameAndUserDetails.DisplayName}"
                                       FontWeight="Bold"
                                       FontSize="16"/>
                            <TextBlock FontSize="13">
                                <Run Text="📍 "/>
                                <Run Text="{Binding GameAndUserDetails.City}"/>
                            </TextBlock>
                        </StackPanel>

                    </Grid>
                </Border>

                <!-- Message user button -->
                <Button Content="Message user"
                        Click="OnMessageUserClicked"
                        HorizontalAlignment="Stretch"
                        Padding="0,12"/>

                <!-- Confirm & Pay -->
                <Button Content="Confirm &amp; Pay"
                        Click="OnConfirmClicked"
                        HorizontalAlignment="Stretch"
                        FontSize="16"
                        Padding="0,12"/>

            </StackPanel>

        </Grid>
    </Grid>
</Page>