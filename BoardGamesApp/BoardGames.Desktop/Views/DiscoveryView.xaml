<Page
    x:Class="BookingBoardGames.Src.Views.DiscoveryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    xmlns:viewModels="using:BoardGames.Desktop.ViewModels"
    xmlns:shared="using:BoardGames.Shared.DTO"
    xmlns:converters="using:BoardGames.Desktop.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
    </Page.Resources>

    <Grid Padding="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0" Spacing="8">

            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
                <Button x:Name="SwitchUserButton" Content="Switch to Carol (User 2)" Click="SwitchUserButton_Click"/>
                <Button Content="Dashboard" Click="DashboardButton_Click"/>
                <Button Content="Chat" Click="ChatButton_Click"/>
            </StackPanel>

            <Border Padding="16"
            CornerRadius="8"
            BorderBrush="LightGray"
            BorderThickness="1">

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="Game name"/>
                        <TextBox x:Name="GameTextBox"
                             PlaceholderText="Enter game name"
                             Text="{Binding Filter.Name, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Text="City"/>
                        <AutoSuggestBox PlaceholderText="Enter city"
                                    Text="{x:Bind ViewModel.CitySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ItemsSource="{x:Bind ViewModel.CitySuggestions, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="6">
                        <TextBlock Text="Start date"/>
                        <CalendarDatePicker x:Name="StartDatePicker"
                        PlaceholderText="Choose a date"
                        MinDate="{Binding MinStartDate}"
                        DateFormat="{}{month.full} {day.integer}, {year.full}"
                        Date="{Binding SelectedStartDate, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Spacing="6">
                        <TextBlock Text="End date"/>
                        <CalendarDatePicker x:Name="EndDatePicker"
                        PlaceholderText="Choose a date"
                        DateFormat="{}{month.full} {day.integer}, {year.full}"
                        Date="{Binding SelectedEndDate, Mode=TwoWay}"
                        CalendarViewDayItemChanging="EndDatePicker_DayItemChanging"
                        IsEnabled="{Binding IsEndDateEnabled}"/>
                    </StackPanel>

                    <Button Grid.Column="4"
                        Content="Filter"
                        Height="40"
                        VerticalAlignment="Bottom"
                        Command="{Binding SearchCommand}"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- RESULTS -->
        <ScrollViewer x:Name="MainScrollViewer"
              Grid.Row="1"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="900"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Spacing="12">

                    <!-- TITLE -->
                    <TextBlock Text="Available Tonight"
                               FontSize="22"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding NoResultsMessage}"
                                FontSize="16"
                                Foreground="Gray"
                                Margin="0,4,0,10"/>

                    <!-- AVAILABLE TONIGHT -->
                    <ListView ItemsSource="{Binding AvailableTonightGames}"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              ItemClick="Game_Click">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="shared:GameDTO">
                                <Border BorderBrush="LightGray"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,0,0,10"
                                        Height="180">
                                    <Grid ColumnDefinitions="220,*"
                                          ColumnSpacing="20">

                                        <Border Grid.Column="0"
                                                CornerRadius="8,0,0,8">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{x:Bind Image, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                                    Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="8">

                                            <TextBlock Text="{x:Bind Name}"
                                                       FontSize="20"
                                                       FontWeight="Bold"/>

                                            <TextBlock Foreground="Gray">
                                                <Run Text="Price: " FontWeight="SemiBold"/>
                                                <Run Text="{x:Bind Price}"/>
                                                <Run Text=" RON/day" FontWeight="SemiBold"/>
                                            </TextBlock>

                                            <TextBlock Foreground="Gray">
                                                <Run Text="City: " FontWeight="SemiBold"/>
                                                <Run Text="{x:Bind City}"/>
                                            </TextBlock>

                                            <TextBlock Foreground="Gray">
                                                <Run Text="Players: " FontWeight="SemiBold"/>
                                                <Run Text="{x:Bind MinimumPlayerNumber}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{x:Bind MaximumPlayerNumber}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- OTHERS TITLE -->
                    <TextBlock Text=" Others games"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding NoResultsMessage}"
                                FontSize="16"
                                Foreground="Gray"
                                Margin="0,4,0,10"/>

                    <!-- OTHERS -->
                    <ListView ItemsSource="{Binding OtherAvailableGames}"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              ItemClick="Game_Click">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="shared:GameDTO">
                                <Border BorderBrush="LightGray"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,0,0,10"
                                        Height="180">
                                    <Grid ColumnDefinitions="220,*"
                                          ColumnSpacing="20">

                                        <Border Grid.Column="0"
                                                CornerRadius="8,0,0,8">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{x:Bind Image, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                                            Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="8">

                                            <TextBlock Text="{x:Bind Name}"
                                                       FontSize="20"
                                                       FontWeight="Bold"/>

                                            <TextBlock Foreground="Gray">
                                                <Run Text="Price: " FontWeight="SemiBold"/>
                                                <Run Text="{x:Bind Price}"/>
                                            </TextBlock>

                                            <TextBlock Foreground="Gray">
                                                <Run Text="City: " FontWeight="SemiBold"/>
                                                <Run Text="{x:Bind City}"/>
                                            </TextBlock>

                                            <TextBlock Foreground="Gray">
                                                <Run Text="Players: " FontWeight="SemiBold"/>
                                                <Run Text="{x:Bind MinimumPlayerNumber}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{x:Bind MaximumPlayerNumber}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- PAGINATION -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="10">
            <Button Content="Previous"
                    Command="{Binding PreviousPageCommand}"/>

            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentPage}"/>
                <TextBlock Text="/"/>
                <TextBlock Text="{Binding TotalPages}"/>
            </StackPanel>

            <Button Content="Next"
                    Command="{Binding NextPageCommand}"/>
        </StackPanel>
    </Grid>
</Page>