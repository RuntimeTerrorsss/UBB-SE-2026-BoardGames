<Page
    x:Class="BoardGames.Desktop.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="40">
        <StackPanel Spacing="24" MaxWidth="1200">
            <TextBlock Text="Dashboard" FontSize="32" FontWeight="SemiBold" />

            <Grid ColumnSpacing="20" RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E3A5F" Padding="20" CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Upcoming Rentals" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                        <ListView ItemsSource="{Binding UpcomingRentals}" SelectionMode="None" MaxHeight="280">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Padding="0,6">
                                        <TextBlock Text="{Binding Game.Name}" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Foreground="#C9D2E3" FontSize="12">
                                            <Run Text="{Binding StartDateDisplay}" />
                                            <Run Text=" – " />
                                            <Run Text="{Binding EndDateDisplay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#4A3F1A" Padding="20" CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Open Requests" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                        <ListView ItemsSource="{Binding OpenRequests}" SelectionMode="None" MaxHeight="280">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Padding="0,6">
                                        <TextBlock Text="{Binding Game.Name}" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Foreground="#E8DDB8" FontSize="12" TextWrapping="WrapWholeWords">
                                            <Run Text="From " />
                                            <Run Text="{Binding Renter.DisplayName}" />
                                            <Run Text=" — " />
                                            <Run Text="{Binding StartDateDisplay}" />
                                            <Run Text=" – " />
                                            <Run Text="{Binding EndDateDisplay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#1A3D2E" Padding="20" CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Recent Payments" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                        <ListView ItemsSource="{Binding RecentPayments}" SelectionMode="None" MaxHeight="280">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" Foreground="White" />
                                            <TextBlock Text="{Binding DateText}" FontSize="12" Foreground="#C9E3D2" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding AmountText}"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
