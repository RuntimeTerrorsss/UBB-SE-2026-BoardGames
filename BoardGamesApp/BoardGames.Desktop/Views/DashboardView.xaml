<Page
    x:Class="BoardGames.Desktop.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="40">
        <StackPanel Spacing="30">
            <TextBlock Text="Dashboard" FontSize="32" FontWeight="SemiBold" />

            <StackPanel Orientation="Horizontal" Spacing="20">
                <Border Background="#333333" Padding="20" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="New Messages" FontSize="13" />
                        <TextBlock Text="{Binding NewMessagesCount}" FontSize="32" FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <Border Background="#333333" Padding="20" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Notifications" FontSize="13" />
                        <TextBlock Text="{Binding PendingNotificationsCount}" FontSize="32" FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Background="#2A2A2A" Padding="20" CornerRadius="8" MaxWidth="600" HorizontalAlignment="Left">
                <StackPanel Spacing="12">
                    <TextBlock Text="Recent Payments" FontSize="16" FontWeight="SemiBold" />
                    <ListView ItemsSource="{Binding RecentPayments}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DateText}" FontSize="12" Foreground="Gray" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding AmountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
