<Page
    x:Class="BoardGames.Desktop.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:BoardGames.Desktop.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F172A" Padding="16">
            <StackPanel Spacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="BoardGames" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                </StackPanel>

                <ListView x:Name="NavigationList"
                          ItemsSource="{Binding NavigationItems}"
                          SelectionMode="Single"
                          SelectionChanged="NavigationList_SelectionChanged"
                          Background="Transparent"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:ShellNavigationItem">
                            <TextBlock Text="{x:Bind Label}" Margin="8,6" Foreground="White" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Column="1" />
    </Grid>
</Page>
