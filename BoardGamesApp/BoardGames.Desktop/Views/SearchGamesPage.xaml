<Page
    x:Class="BoardGames.Desktop.Views.SearchGamesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:BoardGames.Desktop.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <Grid Padding="32" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock Text="Search Games" FontSize="42" FontWeight="Bold" />
                    <TextBlock
                        Text="Browse available games anonymously, then sign in when you want to unlock protected features."
                        FontSize="18"
                        Opacity="0.85"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Content="Login"
                    Command="{Binding NavigateToLoginCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Center"
                    Visibility="{Binding LoginButtonVisibility}" />
            </Grid>

            <Border
                Grid.Row="1"
                Padding="20"
                CornerRadius="12"
                Background="#182238"
                BorderBrush="#24304A"
                BorderThickness="1">
                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                        <TextBlock Text="Game name" />
                        <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                        <TextBlock Text="City" />
                        <TextBox Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Spacing="6">
                        <TextBlock Text="Max price" />
                        <NumberBox Value="{Binding MaximumPrice, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="3" Spacing="6">
                        <TextBlock Text="Player count" />
                        <NumberBox Value="{Binding PlayerCount, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                        <TextBlock Text="Available from" />
                        <CalendarDatePicker Date="{Binding AvailableFrom, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                        <TextBlock Text="Available to" />
                        <CalendarDatePicker Date="{Binding AvailableTo, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Spacing="6">
                        <TextBlock Text="Sort" />
                        <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom">
                        <Button Content="Search" Command="{Binding SearchCommand}" Style="{StaticResource AccentButtonStyle}" />
                        <Button Content="Clear" Command="{Binding ClearCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Spacing="8">
                <ProgressRing IsActive="{Binding IsLoading}" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="WrapWholeWords" />
                <TextBlock Text="{Binding ResultsSummary}" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text="{Binding EmptyStateMessage}" Foreground="Gray" TextWrapping="WrapWholeWords" />
            </StackPanel>

            <ListView
                Grid.Row="3"
                ItemsSource="{Binding Games}"
                SelectionMode="None"
                Margin="0,4,0,0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:SearchGameCardViewModel">
                        <Border
                            Padding="16"
                            Margin="0,0,0,12"
                            CornerRadius="12"
                            Background="#141C2C"
                            BorderBrush="#24304A"
                            BorderThickness="1">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Height="120"
                                    CornerRadius="10"
                                    Background="#23304A">
                                    <Image Source="{x:Bind GameImage}" Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name}" FontSize="24" FontWeight="Bold" TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{x:Bind PriceText}" Foreground="#C9D2E3" />
                                    <TextBlock Text="{x:Bind City}" Foreground="#C9D2E3" />
                                    <TextBlock Text="{x:Bind PlayerRangeText}" Foreground="#C9D2E3" />
                                    <TextBlock Text="{x:Bind OwnerDisplayName}" Foreground="Gray" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </ScrollViewer>
</Page>
